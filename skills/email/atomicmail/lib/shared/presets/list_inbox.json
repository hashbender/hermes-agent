{
  "using": [
    "urn:ietf:params:jmap:core",
    "urn:ietf:params:jmap:mail"
  ],
  "methodCalls": [
    [
      "Email/query",
      {
        "accountId": "$ACCOUNT_ID",
        "filter": {
          "inMailbox": "$INBOX_MAILBOX_ID"
        },
        "sort": [
          {
            "property": "receivedAt",
            "isAscending": false
          }
        ],
        "limit": 50
      },
      "q0"
    ],
    [
      "Email/get",
      {
        "accountId": "$ACCOUNT_ID",
        "#ids": {
          "resultOf": "q0",
          "name": "Email/query",
          "path": "/ids"
        },
        "properties": [
          "id",
          "threadId",
          "receivedAt",
          "from",
          "to",
          "subject",
          "preview"
        ]
      },
      "g0"
    ]
  ]
}
